    <string name="items_empty_title">No items yet</string>
    <string name="items_empty_body">These are the products you regularly buy. Add them here so I can track your consumption and help you build smarter shopping lists.</string>
    <string name="items_onboarding_rate_title">Set a consumption rate</string>
    <string name="items_onboarding_rate_body">Tell me how fast you use each item per day. I\'ll use that to predict when you\'ll run out and remind you to restock.</string>
    <string name="items_onboarding_priority_title">Assign a priority</string>
    <string name="items_onboarding_priority_body">Mark items as High or Highest priority so I always know what\'s most critical when building your shopping list.</string>
    <string name="items_onboarding_shopping_title">Add to your shopping list</string>
    <string name="items_onboarding_shopping_body">Tap ⋮ next to any item to add it to your list, or use the \"+\" button from the Shopping screen to pick multiple at once.</string>
    <string name="items_free_plan_text">You are currently on the free plan. I can remember a maximum of 17 items only. Please upgrade to Premium plan to enable my unlimited memory.</string>
