    <string name="overview_onboarding_title">Let\'s get started</string>
    <string name="overview_onboarding_subtitle">This is your command centre. I watch everything you have at home and alert you the moment something is about to run out.</string>
    <string name="overview_onboarding_track_title">I track what you have</string>
    <string name="overview_onboarding_track_body">Once you add items and log your stock, I\'ll calculate how quickly you\'re using them and predict when you\'ll run out.</string>
    <string name="overview_onboarding_alert_title">I tell you what needs attention</string>
    <string name="overview_onboarding_alert_body">I only surface items that are running low or out of stock — nothing else. One tap and they\'re added to your refill list.</string>
